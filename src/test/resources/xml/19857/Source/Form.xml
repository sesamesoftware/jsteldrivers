                    <ANSWER_CHOICE code="TSOpm071" fqacid="302966" text="Sanitizer reading NOT at 200 PPM-COMMENT"/>
                    <ANSWER_CHOICE code="TSOpm021" fqacid="302982" text="Person In Charge trained on sanitizer testing"/>
                    <ANSWER_CHOICE code="TSOac844" fqacid="303023" text="OTHER-COMMENT"/>
